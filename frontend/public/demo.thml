<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EyeHeat Live Demo</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --ink: #142132;
      --muted: #64748b;
      --accent: #b46445;
      --accent-dark: #8a4b33;
      --border: #e2e8f0;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Segoe UI, Tahoma, sans-serif;
      background: radial-gradient(circle at 20% 20%, #eef2ff, transparent 40%), var(--bg);
      color: var(--ink);
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 20px;
      background: var(--card);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .title {
      font-size: 20px;
      font-weight: 700;
      color: var(--accent);
    }

    .controls {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    button {
      border: none;
      border-radius: 10px;
      padding: 10px 14px;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-dark); }
    .btn-secondary { background: #e2e8f0; color: #0f172a; }

    .layout {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 16px;
      padding: 16px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
    }

    .status {
      color: var(--muted);
      margin-top: 8px;
      font-size: 13px;
    }

    .heatmap {
      position: relative;
      height: 420px;
      border-radius: 12px;
      border: 1px dashed #cbd5e1;
      overflow: hidden;
      background:
        radial-gradient(circle at 15% 20%, rgba(59,130,246,0.08), transparent 42%),
        radial-gradient(circle at 75% 70%, rgba(239,68,68,0.08), transparent 40%),
        #f8fafc;
    }

    .kpis {
      display: grid;
      gap: 12px;
    }

    .kpi {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
    }

    .kpi .label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .kpi .value {
      font-size: 24px;
      font-weight: 700;
      margin-top: 6px;
      color: var(--accent);
    }

    .rows {
      margin-top: 12px;
      display: grid;
      gap: 8px;
    }

    .row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
      padding: 8px 10px;
      border-radius: 10px;
      background: #f8fafc;
    }

    @media (max-width: 960px) {
      .layout { grid-template-columns: 1fr; }
      .heatmap { height: 320px; }
    }
  </style>
  <script src="https://webgazer.cs.brown.edu/webgazer.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/heatmap.js@2.0.5/build/heatmap.min.js"></script>
</head>
<body>
  <div class="header">
    <div>
      <div class="title">EyeHeat Live Demo</div>
      <div class="status" id="status">Idle. Click Start Tracking.</div>
    </div>
    <div class="controls">
      <button class="btn-primary" id="startBtn">Start Tracking</button>
      <button class="btn-secondary" id="stopBtn">Stop</button>
      <button class="btn-secondary" onclick="window.close()">Close</button>
    </div>
  </div>

  <div class="layout">
    <div class="card">
      <h3>Live Heatmap</h3>
      <p class="status">This heatmap is generated from live gaze points pushed to backend every 3 seconds.</p>
      <div id="heatmap" class="heatmap"></div>
    </div>

    <div class="card">
      <h3>Live KPIs</h3>
      <div class="kpis">
        <div class="kpi"><div class="label">Sessions</div><div class="value" id="sessions">0</div></div>
        <div class="kpi"><div class="label">Gaze Points</div><div class="value" id="points">0</div></div>
        <div class="kpi"><div class="label">Bounce Rate</div><div class="value" id="bounce">0.0%</div></div>
        <div class="kpi"><div class="label">Avg Session Time</div><div class="value" id="duration">0s</div></div>
      </div>

      <div class="rows" id="topPages"></div>
    </div>
  </div>

  <script>
    const API_BASE = 'http://localhost:3001/api';

    const statusEl = document.getElementById('status');
    const sessionsEl = document.getElementById('sessions');
    const pointsEl = document.getElementById('points');
    const bounceEl = document.getElementById('bounce');
    const durationEl = document.getElementById('duration');
    const topPagesEl = document.getElementById('topPages');

    const state = {
      active: false,
      sessionId: '',
      localPoints: [],
      uploadQueue: [],
      batchTimer: null,
      statsTimer: null,
      heatmap: null,
    };

    function formatDuration(ms) {
      const sec = Math.round((ms || 0) / 1000);
      const m = Math.floor(sec / 60);
      const s = sec % 60;
      return m ? `${m}m ${s}s` : `${s}s`;
    }

    function setStatus(text) {
      statusEl.textContent = text;
    }

    function normalizePoints(points, width, height) {
      if (!points.length) return [];
      const xs = points.map((p) => p.x);
      const ys = points.map((p) => p.y);
      const minX = Math.min(...xs);
      const maxX = Math.max(...xs);
      const minY = Math.min(...ys);
      const maxY = Math.max(...ys);
      const xRange = Math.max(1, maxX - minX);
      const yRange = Math.max(1, maxY - minY);

      return points.map((p) => ({
        x: Math.round(((p.x - minX) / xRange) * Math.max(1, width - 12) + 6),
        y: Math.round(((p.y - minY) / yRange) * Math.max(1, height - 12) + 6),
        value: 1,
      }));
    }

    function renderHeatmap() {
      if (!state.heatmap) return;
      const container = document.getElementById('heatmap');
      const data = normalizePoints(state.localPoints.slice(-2000), container.clientWidth, container.clientHeight);
      state.heatmap.setData({ max: 8, data });
    }

    async function fetchStats() {
      const res = await fetch(`${API_BASE}/stats/live`);
      if (!res.ok) return;
      const data = await res.json();
      const totals = data.totals || {};

      sessionsEl.textContent = `${totals.sessions || 0}`;
      pointsEl.textContent = `${totals.points || 0}`;
      bounceEl.textContent = `${Number(totals.bounceRate || 0).toFixed(1)}%`;
      durationEl.textContent = formatDuration(totals.avgDurationMs || 0);

      topPagesEl.innerHTML = '';
      (data.topPages || []).slice(0, 4).forEach((page) => {
        const row = document.createElement('div');
        row.className = 'row';
        row.innerHTML = `<span>${page.page}</span><strong>${page.sessions} sessions</strong>`;
        topPagesEl.appendChild(row);
      });
    }

    async function flushBatch() {
      if (!state.sessionId || !state.uploadQueue.length) return;
      const points = state.uploadQueue.slice();
      state.uploadQueue = [];

      await fetch(`${API_BASE}/gaze/batch`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId: state.sessionId, points }),
      });
    }

    async function startTracking() {
      if (state.active) return;

      try {
        const startRes = await fetch(`${API_BASE}/gaze/start`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pageUrl: window.location.href }),
        });

        if (!startRes.ok) throw new Error('Unable to create session');
        const started = await startRes.json();
        state.sessionId = started.sessionId;

        await window.webgazer
          .setRegression('ridge')
          .setTracker('TFFacemesh')
          .setGazeListener((data) => {
            if (!data || !state.active) return;
            const point = { x: data.x, y: data.y, ts: Date.now() };
            state.localPoints.push(point);
            state.uploadQueue.push(point);
            renderHeatmap();
          })
          .begin();

        window.webgazer.showVideoPreview(true);
        window.webgazer.showFaceOverlay(false);
        window.webgazer.showPredictionPoints(false);

        state.active = true;
        state.batchTimer = setInterval(flushBatch, 3000);
        state.statsTimer = setInterval(fetchStats, 4000);

        setStatus(`Tracking live. Session: ${state.sessionId.slice(0, 8)}...`);
        await fetchStats();
      } catch (err) {
        setStatus(`Start failed: ${err.message}`);
      }
    }

    async function stopTracking() {
      if (!state.active) return;

      state.active = false;
      clearInterval(state.batchTimer);
      clearInterval(state.statsTimer);
      state.batchTimer = null;
      state.statsTimer = null;

      await flushBatch();

      if (state.sessionId) {
        await fetch(`${API_BASE}/gaze/end`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId: state.sessionId }),
        });
      }

      try {
        window.webgazer.clearGazeListener();
        window.webgazer.end();
      } catch (_err) {
        // no-op
      }

      setStatus('Tracking stopped. Metrics remain live from backend.');
      state.sessionId = '';
      await fetchStats();
    }

    window.addEventListener('beforeunload', () => {
      if (state.active) {
        stopTracking();
      }
    });

    document.getElementById('startBtn').addEventListener('click', startTracking);
    document.getElementById('stopBtn').addEventListener('click', stopTracking);

    state.heatmap = window.h337.create({
      container: document.getElementById('heatmap'),
      radius: 28,
      maxOpacity: 0.72,
      minOpacity: 0.05,
      blur: 0.86,
      gradient: {
        0.2: '#3b82f6',
        0.45: '#22c55e',
        0.7: '#f59e0b',
        1.0: '#ef4444',
      },
    });

    fetchStats();
  </script>
</body>
</html>
